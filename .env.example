# =============================================================================
# UniFlow College Portal — Environment Variables
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# =============================================================================

# ===== POSTGRESQL (via Prisma) =====
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
#
# Two URLs are configured below:
#   DATABASE_URL — app traffic. Points at PgBouncer (port 6432) when the pooler
#                  is running (`npm run pgbouncer:up`). The query-string flags
#                  `?pgbouncer=true&connection_limit=1` are MANDATORY in
#                  transaction-pooling mode — Prisma disables prepared
#                  statements and limits each app instance to one connection
#                  (PgBouncer handles the multiplexing).
#   DIRECT_URL   — migrations + introspection. Bypasses PgBouncer so Prisma's
#                  advisory-lock-based migration runner works. Point at the
#                  real Postgres port (5432).
#
# If you don't run PgBouncer, point DATABASE_URL straight at 5432 and leave
# DIRECT_URL blank or matching DATABASE_URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:6432/uniflow?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/uniflow"

# ===== JWT =====
# Use a long random string in production. Generate with: openssl rand -hex 32
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# ===== SMTP EMAIL (used by user-profile server) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=UniFlow Portal

# ===== SERVER PORTS =====
WS_PORT=4001
REG_PORT=4002
ATTENDANCE_PORT=4003
PAYMENTS_PORT=4004
CONTENT_PORT=4005
AFFAIRS_PORT=4006
PORT_PROFILE=4007
CHATBOT_PORT=4008
NOTIFICATION_PORT=4009
CHAT_PORT=4010

# ===== MISTRAL AI (chatbot) =====
# Get a key from https://console.mistral.ai/api-keys
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-medium-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# ===== LIVE SESSIONS (LiveKit) =====
# UniFlow's live-session room (`LiveSessionRoom.tsx`) embeds video via
# LiveKit Components, which gives full programmatic control of every
# meeting feature (mic / cam / screen share / recording / whiteboard).
# Replaces the prior Jitsi iframe (kept legacy `MEETING_URL_BASE` below for
# backward compat but no longer used by the in-app room).
#
# Two ways to get LiveKit running:
#
# 1) LiveKit Cloud (zero setup, 10,000 free min/month):
#    a. Sign up at https://livekit.io
#    b. Create a project, copy the URL + API_KEY + API_SECRET
#    c. Paste here. Restart `npm run content-server`.
#
# 2) Self-host via Docker (no external dependency):
#    a. `cd docker/livekit && docker compose up -d`
#    b. Use the values below:
#       LIVEKIT_URL=ws://localhost:7880
#       LIVEKIT_API_KEY=devkey
#       LIVEKIT_API_SECRET=secret-please-change-me-32-chars-min
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ===== LEGACY MEETING_URL_BASE (Jitsi) =====
# No longer used by the in-app room (replaced by LiveKit above). Kept only
# as a no-op for older session rows that still store a meetingLink string.
MEETING_URL_BASE=https://meet.jit.si/uniflow-

# ===== FIREBASE CLOUD MESSAGING (push notifications) =====
# All Firebase wiring is OPTIONAL — without these vars, push notifications are
# disabled but everything else still works (Socket.io + DB notifications keep
# functioning). Setup runbook: docs/firebase-setup.md
#
# Backend: paste the entire service-account JSON either as raw JSON or as
# base64 of the JSON. Pick whichever your hosting provider's secret store
# handles cleanly.
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_PROJECT_ID=

# ===== WEB PUSH (VAPID) — standard Web Push, required for iOS PWA background push =====
# FCM's web SDK does NOT work on iOS Safari (isSupported() returns false), so an
# installed iOS PWA (iOS 16.4+) needs standard VAPID Web Push instead. This also
# works on Chrome/Edge/Firefox. Generate a key pair once with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# The public key is served to the frontend at GET /api/push/vapid-public-key;
# the private key stays server-side. VAPID_SUBJECT is a contact mailto: URL.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@uni-flow.tech

# ===== FRONTEND (CRA — must be REACT_APP_*) =====
REACT_APP_CHATBOT_URL=http://localhost:4008/api
REACT_APP_WS_URL=http://localhost:4001
# Optional: override the API host (without port) for all backends.
# REACT_APP_API_URL=http://192.168.1.100

# ===== FIREBASE CLOUD MESSAGING — frontend (CRA) =====
# Copy from Firebase Console → Project Settings → Your apps → Web app config.
# Leave blank to disable push notifications client-side. The same values must
# also be hardcoded into frontend/public/firebase-messaging-sw.js (CRA does
# not template env vars into public/).
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
# Web Push VAPID public key (Firebase Console → Cloud Messaging → Web configuration)
REACT_APP_FIREBASE_VAPID_KEY=

# ===== REDIS (shared cache, session store, rate-limit store) =====
# Optional in development. When set, the following caches become process-shared:
#   - chatbot sessions (was: in-memory Map per process)
#   - permission cache in backend/lib/auth.js (was: 5-min per-process Map)
#   - express-rate-limit counters (was: in-memory per process)
#
# Without REDIS_URL, every consumer falls back to its in-memory behaviour;
# nothing breaks, you just lose cross-process coherence and restart-survival.
#
# Run: npm run redis:up
REDIS_URL=

# ===== MULTI-TENANT =====
# Hostname → tenant resolution. Set DEFAULT_TENANT_CODE to the tenant code that
# pre-existing rows (and the seed) belong to. New tenants are created via
# `POST /api/admin/tenants` (admin-only). See docs/multi-tenant.md.
DEFAULT_TENANT_CODE=fcds

# ===== CORS =====
CORS_ORIGIN=http://localhost:3000

# ===== LOGGING =====
# Plan 10 (code quality): privacy-sensitive logs (mock-email body, chat
# message content) are gated on LOG_LEVEL=debug so production deploys keep
# them silent. Leave unset (or set to anything other than `debug`) in prod.
# A proper structured logger (pino/winston) is tracked as a future plan.
LOG_LEVEL=

# ===== STRIPE (payments) =====
# All invoice payments flow through Stripe Checkout. Get keys at:
#   https://dashboard.stripe.com/test/apikeys   (Test/sandbox mode)
#   https://dashboard.stripe.com/apikeys        (Live mode — production only)
#
# Backend secret key — KEEP THIS PRIVATE. Never commit, never expose to frontend.
STRIPE_SECRET_KEY=
#
# Webhook signing secret. Get this from the Stripe dashboard when you create the
# webhook endpoint, OR run `stripe listen --forward-to localhost:4004/api/payments/stripe/webhook`
# locally and use the `whsec_...` value the CLI prints. The webhook handler refuses
# any event whose signature doesn't validate against this secret.
STRIPE_WEBHOOK_SECRET=
#
# Frontend publishable key — safe to ship in JS bundle.
REACT_APP_STRIPE_PUBLISHABLE_KEY=
#
# Public URLs the user is redirected to after Stripe Checkout completes or is cancelled.
# In dev these point at the CRA dev server. In prod, set them to your deployed origin.
STRIPE_SUCCESS_URL=http://localhost:3000/student/payments/success
STRIPE_CANCEL_URL=http://localhost:3000/student/payments

# ===== UNPAID-FEES AUTO-LOCK =====
# Daily cron in the payments server scans for students with overdue invoices.
# If any invoice has dueDate < (today - UNPAID_LOCK_GRACE_DAYS) AND balance > 0,
# the student receives a sign-in lock (LoginLock kind=user, reason=unpaid_fees).
# The lock auto-releases when the user pays and their balance hits zero.
# Set to 0 to lock immediately on any overdue invoice; leave default for the
# 14-day grace period.
UNPAID_LOCK_GRACE_DAYS=14
# Cron schedule — defaults to 03:00 every day (server time). Standard 5-field cron.
UNPAID_LOCK_CRON="0 3 * * *"
# Set to "false" to disable the cron entirely (useful in dev / CI).
UNPAID_LOCK_ENABLED=true
