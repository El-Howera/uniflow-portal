# UniFlow — npm config (root)
#
# legacy-peer-deps = npm v6-style peer dep resolution. Required because
# react-scripts@5.0.0 declares `peer typescript: ^3.2.1 || ^4` but the
# project runs on TypeScript 5.9.3 (upgraded under Plan 21 Phase 1.3 to
# clear VS Code's TS-5.x schema deprecations). The peer is advisory; TS 5
# works fine with CRA 5 at build + test time.
#
# Without this flag, npm 9+'s strict resolution makes `npm ci` ERESOLVE-fail
# in CI even though local installs (which use --legacy-peer-deps) succeed.
# Mirrors the same flag baked into frontend/Dockerfile (Plan 15 stack).
legacy-peer-deps=true

# Skip optional dependency installation noise. npm prints OK without it.
fund=false
audit=false
