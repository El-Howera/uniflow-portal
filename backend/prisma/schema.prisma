}

// Plan 4 Phase 6 — shared lifecycle for the three enrollment workflows
// (suspension, cancellation, programme change). `withdrawn` lets a student
// retract their own request before SA reviews it.
enum SuspensionStatus {
  pending
  approved
  rejected
  withdrawn
}

// Plan 4 Phase 6 — Article 20 (suspension), Article 21 (cancellation), and
// Article 23 (programme change). Three sibling models that all share the
// pending → approved/rejected/withdrawn lifecycle but carry different
// workflow-specific fields.
