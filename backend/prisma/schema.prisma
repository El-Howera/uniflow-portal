// ============================================================================
// UniFlow College Portal — Prisma Schema
// Backed by PostgreSQL. Migrations live in backend/prisma/migrations/.
// Run: npx prisma migrate dev --name <change_name>
// ============================================================================
//
// MULTI-TENANCY (added 2026-05-18) — Every row in every table (except `Tenant`
// itself) carries a `tenantId String` column referencing `Tenant.id`. Tenant
// scope is enforced at runtime by a Prisma Client Extension in
// `backend/lib/prisma.js` that reads `AsyncLocalStorage` for the current
// tenant id and auto-injects `where: { tenantId }` on every query plus
// `data: { tenantId }` on every write. The `requireAuth` middleware wraps the
// downstream handler in `runWithTenant(req.user.tenantId, ...)`; unauthenticated
// routes (login, tenant lookup) resolve the tenant from the subdomain / header /
// query / DEFAULT_TENANT_CODE env var.
//
// Every previously-`@unique` field (e.g. `User.email`) is now part of a
// composite `@@unique([tenantId, field])` so the same value (same email,
// course code, etc.) can exist in two tenants without collision.
// ============================================================================

generator client {
  provider      = "prisma-client-js"
  // `native` covers local dev (Windows/macOS/Linux glibc). The musl targets
  // are REQUIRED for the Fly deploy — the runtime image is node:20-alpine
  // which uses musl + OpenSSL 3.x. Without these targets the @prisma/client
  // runtime can't find a usable engine binary and crashes with
  // "could not find Prisma Query Engine binary for Linux Alpine".
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider  = "postgresql"
  // App traffic. With PgBouncer in `transaction` pool mode this URL must end
  // with `?pgbouncer=true&connection_limit=1` (see docker/pgbouncer/README.md
  // and .env.example).
  url       = env("DATABASE_URL")
  // Direct connection for migrations + introspection (bypasses PgBouncer so
  // Prisma's advisory-lock-based migration runner works correctly). Falls
  // back to DATABASE_URL when unset, so single-DB setups keep working.
  directUrl = env("DIRECT_URL")
}

