model StudentAccount {
  id                  String    @id @default(cuid())
  tenantId            String    @map("tenant_id")
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId              String    @unique @map("user_id")
  balance             Decimal   @default(0.00) @db.Decimal(10, 2)
  currency            String    @default("EGP")
  totalPaid           Decimal   @default(0.00) @map("total_paid") @db.Decimal(10, 2)
  financialAidApplied Decimal   @default(0.00) @map("financial_aid_applied") @db.Decimal(10, 2)
  paymentPlan         String    @default("semester") @map("payment_plan")
  lastPaymentDate     DateTime? @map("last_payment_date")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("student_accounts")
}

model Invoice {
  id          String          @id @default(cuid())
  tenantId    String          @map("tenant_id")
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String          @map("user_id")
  semesterId  String?         @map("semester_id")
  title       String
  description String?
  category    InvoiceCategory @default(other)
  amount      Decimal         @db.Decimal(10, 2)
  vatAmount   Decimal         @default(0.00) @map("vat_amount") @db.Decimal(10, 2)
  totalAmount Decimal         @db.Decimal(10, 2)
  paid        Decimal         @default(0.00) @db.Decimal(10, 2)
  balance     Decimal         @db.Decimal(10, 2)
  status      InvoiceStatus   @default(pending)
  dueDate     DateTime        @map("due_date")
  paidAt      DateTime?       @map("paid_at")
  semester    String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  semesterRef  Semester?     @relation(fields: [semesterId], references: [id])
  transactions Transaction[]

  @@index([userId, status])
  @@index([tenantId])
  @@map("invoices")
}

model Transaction {
  id                    String            @id @default(cuid())
  tenantId              String            @map("tenant_id")
  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId                String            @map("user_id")
  invoiceId             String?           @map("invoice_id")
  paymentMethodId       String?           @map("payment_method_id")
  type                  TransactionType
  method                String?
  amount                Decimal           @db.Decimal(10, 2)
  description           String?
  status                TransactionStatus @default(pending)
  cardLast4             String?           @map("card_last4")
  referenceNumber       String?           @map("reference_number")
  confirmedById         String?           @map("confirmed_by_id")
  confirmedAt           DateTime?         @map("confirmed_at")
  notes                 String?
  // Stripe linkage. `stripeSessionId` is set when the Checkout Session is
  // created and lets the success page look up the row without exposing the
  // PaymentIntent ID to the URL. `stripePaymentIntentId` is filled by the
  // webhook on `payment_intent.succeeded` and is the canonical idempotency
  // key — the webhook handler checks for an existing row with this value
  // before creating one, so retries don't double-credit. `stripeChargeId`
  // supports a future refund flow via Stripe.
  stripeSessionId       String?           @map("stripe_session_id")
  stripePaymentIntentId String?           @map("stripe_payment_intent_id")
  stripeChargeId        String?           @map("stripe_charge_id")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice       Invoice?       @relation(fields: [invoiceId], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@unique([tenantId, referenceNumber])
  @@unique([tenantId, stripePaymentIntentId])
  @@unique([tenantId, stripeSessionId])
  @@index([tenantId])
  @@index([stripePaymentIntentId])
  @@map("transactions")
}

model PaymentMethod {
  id          String            @id @default(cuid())
  tenantId    String            @map("tenant_id")
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String            @map("user_id")
  type        PaymentMethodType
  brand       String?
  last4       String?
  lastFour    String?           @map("last_four")
  expiryMonth Int?              @map("expiry_month")
  expiryYear  Int?              @map("expiry_year")
  expiryDate  String?           @map("expiry_date")
  holderName  String?           @map("holder_name")
  isDefault   Boolean           @default(false) @map("is_default")
  isActive    Boolean           @default(true) @map("is_active")
  nickname    String?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([tenantId])
  @@map("payment_methods")
}

enum FeeCategory {
  registration
  document
  lab
  tuition
  library
  housing
  exam
  sports
  other

