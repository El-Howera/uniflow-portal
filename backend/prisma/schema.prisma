// ============================================================================
// 10b. PAYROLL  (Phase 10 — staff employment + monthly payroll runs)
// ============================================================================

enum EmploymentType {
  full_time
  part_time
  contract
  hourly
  intern

  @@map("employment_type")
}

enum PayrollRunStatus {
  draft
  finalized
  paid
  cancelled

  @@map("payroll_run_status")
}

enum DeductionType {
  tax
  insurance
  loan
  advance
  custom

  @@map("deduction_type")
}

/// Per-staff (professor / TA / SA / admin) HR record. One row per user, lazily
/// created the first time an admin opens the Employment tab on UserEditPage.
/// Decoupled from `User` so students don't carry these fields.
model EmployeeProfile {
  id              String         @id @default(cuid())
  tenantId        String         @map("tenant_id")
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String         @unique @map("user_id")
  employmentType  EmploymentType @default(full_time) @map("employment_type")
  hireDate        DateTime?      @map("hire_date")
  terminationDate DateTime?      @map("termination_date")
  position        String?
  office          String?
  payrollId       String?        @map("payroll_id")
  contractType    String?        @map("contract_type")
  baseSalary      Decimal        @default(0.00) @map("base_salary") @db.Decimal(12, 2)
  currency        String         @default("EGP")
  bankName        String?        @map("bank_name")
  bankAccount     String?        @map("bank_account")
  taxId           String?        @map("tax_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, payrollId])
  @@index([tenantId])
  @@map("employee_profiles")
}

/// One PayrollRun per period (e.g. "2026-04"). Creates a Payslip per staff
/// member with an EmployeeProfile at run time. Status flow:
///   draft → finalized → paid  (or cancelled).
model PayrollRun {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period          String // "YYYY-MM"
  runDate         DateTime         @default(now()) @map("run_date")
  status          PayrollRunStatus @default(draft)
  totalGross      Decimal          @default(0.00) @map("total_gross") @db.Decimal(14, 2)
  totalNet        Decimal          @default(0.00) @map("total_net") @db.Decimal(14, 2)
  totalDeductions Decimal          @default(0.00) @map("total_deductions") @db.Decimal(14, 2)
  currency        String           @default("EGP")
  notes           String?
  runById         String?          @map("run_by_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  runBy    User?     @relation("PayrollRunner", fields: [runById], references: [id])
  payslips Payslip[]

  @@unique([tenantId, period])
  @@index([tenantId])
  @@map("payroll_runs")
}

model Payslip {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollRunId    String   @map("payroll_run_id")
  userId          String   @map("user_id")
  gross           Decimal  @db.Decimal(12, 2)
  deductionsTotal Decimal  @default(0.00) @map("deductions_total") @db.Decimal(12, 2)
  net             Decimal  @db.Decimal(12, 2)
  generatedAt     DateTime @default(now()) @map("generated_at")
  pdfUrl          String?  @map("pdf_url")
  notes           String?

  payrollRun PayrollRun  @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  user       User        @relation("PayslipUser", fields: [userId], references: [id])
  deductions Deduction[]

  @@unique([payrollRunId, userId])
  @@index([userId])
  @@index([tenantId])
  @@map("payslips")
}

model Deduction {
  id          String        @id @default(cuid())
  tenantId    String        @map("tenant_id")
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payslipId   String        @map("payslip_id")
  type        DeductionType @default(custom)
  amount      Decimal       @db.Decimal(12, 2)
  description String?
  createdAt   DateTime      @default(now()) @map("created_at")

  payslip Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  @@index([payslipId])
  @@index([tenantId])
  @@map("deductions")
}

// ============================================================================
// 11. STUDENT AFFAIRS
// ============================================================================

model DepartmentContact {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deptKey     String?  @map("dept_key")
  department  String
  title       String
  name        String?
  role        String?
  email       String?
  phone       String?
  office      String?
  hours       String?
  location    String?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, deptKey])
  @@index([tenantId])
  @@map("department_contacts")
}

// ============================================================================
// Plan 7 Phase 4 — Generic Form Composer
// Any non-student role can create a form (questions + recipient targeting +
// schedule), students respond, creator + admin review. One response per
// user per form (re-submission edits the same row).
// ============================================================================
model Form {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  bannerImage   String?  @map("banner_image")
  startDate     DateTime @map("start_date")
  dueDate       DateTime @map("due_date")
  // Recipient targeting (mirrors Announcement.targetRoles/Levels/UserIds).
  targetRoles   String[] @default([]) @map("target_roles")
  targetLevels  Int[]    @default([]) @map("target_levels")
  targetUserIds String[] @default([]) @map("target_user_ids")
  isPublished   Boolean  @default(false) @map("is_published")
  createdById   String   @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  createdBy User           @relation("FormCreator", fields: [createdById], references: [id], onDelete: Restrict)
  questions FormQuestion[]
  responses FormResponse[]

  @@index([createdById])
  @@index([dueDate])
  @@index([tenantId])
  @@map("forms")
}

model FormQuestion {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  formId    String   @map("form_id")
  order     Int      @default(0)
  // 'text' | 'textarea' | 'multiple-choice' | 'checkboxes' | 'dropdown' | 'date' | 'image-upload' | 'file-upload'
  kind      String
  label     String
  required  Boolean  @default(false)
  options   Json     @default("[]")
  maxLength Int?     @map("max_length")
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  form    Form                 @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers FormResponseAnswer[]

  @@index([formId, order])
  @@index([tenantId])
  @@map("form_questions")
}

model FormResponse {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  formId       String   @map("form_id")
  respondentId String   @map("respondent_id")
  submittedAt  DateTime @default(now()) @map("submitted_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  form       Form                 @relation(fields: [formId], references: [id], onDelete: Cascade)
  respondent User                 @relation("FormRespondent", fields: [respondentId], references: [id], onDelete: Cascade)
  answers    FormResponseAnswer[]

  @@unique([formId, respondentId])
  @@index([formId])
  @@index([respondentId])
  @@index([tenantId])
  @@map("form_responses")
}

model FormResponseAnswer {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  responseId   String   @map("response_id")
  questionId   String   @map("question_id")
  textValue    String?  @map("text_value")
  choiceValues String[] @default([]) @map("choice_values")
  fileUrl      String?  @map("file_url")
  createdAt    DateTime @default(now()) @map("created_at")

  response FormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question FormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([responseId, questionId])
  @@index([questionId])
  @@index([tenantId])
  @@map("form_response_answers")
}

// ============================================================================
// Plan 7 Phase 6 — Financial Aid Request
// Student-facing application; admin or `financial` role reviews; on approve
// a NEGATIVE-amount Transaction is created against the next open invoice
// to deliver the discount.
// ============================================================================
model FinancialAidRequest {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId           String    @map("user_id")
  applicantIncome  Decimal?  @map("applicant_income") @db.Decimal(12, 2)
  dependents       Int?
  requestedAmount  Decimal   @map("requested_amount") @db.Decimal(12, 2)
  justification    String
  supportingDocs   Json      @default("[]") @map("supporting_docs")
  // 'pending' | 'approved' | 'rejected' | 'withdrawn'
  status           String    @default("pending")
  reviewedById     String?   @map("reviewed_by_id")
  reviewedAt       DateTime? @map("reviewed_at")
  reviewNote       String?   @map("review_note")
  awardedAmount    Decimal?  @map("awarded_amount") @db.Decimal(12, 2)
  awardedInvoiceId String?   @map("awarded_invoice_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user     User  @relation("FinancialAidApplicant", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("FinancialAidReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([tenantId])
  @@map("financial_aid_requests")
}

model RequestType {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  typeKey        String?  @map("type_key")
  name           String
  department     String?
  description    String?
  category       String?
  requiredDocs   String[] @default([]) @map("required_docs")
  processingDays Int      @default(3) @map("processing_days")
  estimatedDays  Int      @default(5) @map("estimated_days")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  supportRequests SupportRequest[]

  @@unique([tenantId, typeKey])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("request_types")
}

// SA-managed taxonomy for complaint categories. The student "Submit a
// Complaint" form fetches this list at render time (no more hardcoded
// categories), and SA / admin filter their queues by `category_key`.
// Free-text `Complaint.category` column stores the chosen key.
model ComplaintCategory {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryKey     String   @map("category_key")
  name            String
  description     String?
  icon            String?
  defaultSeverity String   @default("medium") @map("default_severity")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, categoryKey])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("complaint_categories")
}

model SupportRequest {
  id             String          @id @default(cuid())
  tenantId       String          @map("tenant_id")
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String          @map("user_id")
  typeId         String?         @map("type_id")
  studentName    String?         @map("student_name")
  studentEmail   String?         @map("student_email")
  type           String?
  typeName       String?         @map("type_name")
  subject        String
  description    String
  message        String?
  status         RequestStatus   @default(pending)
  priority       RequestPriority @default(medium)
  assignedToId   String?         @map("assigned_to_id")
  response       String?
  resolution     String?
  notes          String?
  attachments    String[]        @default([])
  attachmentPath String?         @map("attachment_path")
  estimatedDays  Int?            @map("estimated_days")
  resolvedAt     DateTime?       @map("resolved_at")
  // Processor tracking — written when SA / admin flips status to in_progress
  // (so the student sees "Being processed by Name — since timestamp" inline).
  processedById  String?         @map("processed_by_id")
  processedAt    DateTime?       @map("processed_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestType RequestType? @relation(fields: [typeId], references: [id])
  assignedTo  User?        @relation("SupportRequestAssignee", fields: [assignedToId], references: [id])
  processedBy User?        @relation("SupportRequestProcessor", fields: [processedById], references: [id])

  @@index([tenantId])
  @@map("support_requests")
}

model Announcement {
  id             String               @id @default(cuid())
  tenantId       String               @map("tenant_id")
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title          String
  subtitle       String?
  content        String
  fullContent    String?              @map("full_content")
  date           DateTime             @default(now())
  authorId       String?              @map("author_id")
  author         String               @default("Administration")
  readTime       String?              @map("read_time")
  category       AnnouncementCategory @default(general)
  priority       AnnouncementPriority @default(normal)
  imageUrl       String?              @map("image_url")
  audience       String               @default("all-students")
  audienceDetail String?              @map("audience_detail")
  source         String               @default("admin")
  targetRoles    UserRole[]           @default([])
  // When non-empty, only these users see the announcement (overrides
  // targetRoles + audience). Used by "Specific Students" recipient mode.
  targetUserIds  String[]             @default([]) @map("target_user_ids")
  // When non-empty, only students whose AcademicProfile.level is in this set
  // see the announcement. Used by "Specific Levels" recipient mode.
  targetLevels   Int[]                @default([]) @map("target_levels")
  isPublished    Boolean              @default(true) @map("is_published")
  publishedAt    DateTime?            @map("published_at")
  expiresAt      DateTime?            @map("expires_at")
  attachmentPath String?              @map("attachment_path")
  tags           String[]             @default([])
  viewCount      Int                  @default(0) @map("view_count")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  authorUser User? @relation("AnnouncementAuthor", fields: [authorId], references: [id])

  @@index([authorId, publishedAt])
  @@index([tenantId])
  @@map("announcements")
}

model Complaint {
  id              String            @id @default(cuid())
  tenantId        String            @map("tenant_id")
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  complainantId   String            @map("complainant_id")
  targetUserId    String?           @map("target_user_id")
  category        String
  severity        ComplaintSeverity @default(medium)
  subject         String
  description     String
  status          RequestStatus     @default(pending)
  resolutionNotes String?           @map("resolution_notes")
  resolvedById    String?           @map("resolved_by_id")
  resolvedAt      DateTime?         @map("resolved_at")
  // Processor tracking — mirrors SupportRequest. Written when SA / admin
  // flips status to in_progress.
  processedById   String?           @map("processed_by_id")
  processedAt     DateTime?         @map("processed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  complainant User  @relation("Complainant", fields: [complainantId], references: [id])
  targetUser  User? @relation("ComplaintTarget", fields: [targetUserId], references: [id])
  resolvedBy  User? @relation("ComplaintResolver", fields: [resolvedById], references: [id])
  processedBy User? @relation("ComplaintProcessor", fields: [processedById], references: [id])

  @@index([tenantId])
  @@map("complaints")
}

// ============================================================================
// 12. CHAT & NOTIFICATIONS
