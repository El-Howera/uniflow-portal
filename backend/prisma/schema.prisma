// ============================================================================
// 0. TENANTS (Multi-tenancy root)
// ============================================================================

/// Each Tenant is an isolated institution (e.g. FCDS Alexandria, or another
/// faculty using the same UniFlow installation). The `code` is the short
/// slug used for subdomain resolution (`<code>.uniflow.app`) and the
/// `X-Tenant-Code` header. Every other table row carries `tenantId`
/// referencing `Tenant.id`; the Prisma extension in
/// `backend/lib/prisma.js` enforces the filter on every query/mutation.
model Tenant {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  shortName String?  @map("short_name")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                   User[]
  userAddresses           UserAddress[]
  emergencyContacts       EmergencyContact[]
  userSettings            UserSettings[]
  sessions                Session[]
  verificationCodes       VerificationCode[]
  resetTokens             ResetToken[]
  refreshTokens           RefreshToken[]
  academicProfiles        AcademicProfile[]
  semesters               Semester[]
  transcriptCourses       TranscriptCourse[]
  gradeBreakdowns         GradeBreakdown[]
  semesterGpas            SemesterGpa[]
  departments             Department[]
  courses                 Course[]
  courseDepartments       CourseDepartment[]
  courseSections          CourseSection[]
  sectionSlots            SectionSlot[]
  registrations           Registration[]
  registrationPeriods     RegistrationPeriod[]
  registrationSwaps       RegistrationSwap[]
  courseMaterials         CourseMaterial[]
  studentProgresses       StudentProgress[]
  courseRemarks           CourseRemark[]
  lectures                Lecture[]
  lectureProgresses       LectureProgress[]
  assignments             Assignment[]
  assignmentSubmissions   AssignmentSubmission[]
  quizzes                 Quiz[]
  quizQuestions           QuizQuestion[]
  quizSubmissions         QuizSubmission[]
  quizAnswers             QuizAnswer[]
  gradebookEntries        GradebookEntry[]
  bssidLocations          BssidLocation[]
  courseSchedules         CourseSchedule[]
  attendanceSessions      AttendanceSession[]
  attendanceRecords       AttendanceRecord[]
  cheatingFlags           CheatingFlag[]
  studentEnrollments      StudentEnrollment[]
  attendanceExcuses       AttendanceExcuse[]
  studentAccounts         StudentAccount[]
  invoices                Invoice[]
  transactions            Transaction[]
  paymentMethods          PaymentMethod[]
  serviceFees             ServiceFee[]
  serviceRequests         ServiceRequest[]
  employeeProfiles        EmployeeProfile[]
  payrollRuns             PayrollRun[]
  payslips                Payslip[]
  deductions              Deduction[]
  departmentContacts      DepartmentContact[]
  forms                   Form[]
  formQuestions           FormQuestion[]
  formResponses           FormResponse[]
  formResponseAnswers     FormResponseAnswer[]
  financialAidRequests    FinancialAidRequest[]
  requestTypes            RequestType[]
  complaintCategories     ComplaintCategory[]
  supportRequests         SupportRequest[]
  announcements           Announcement[]
  complaints              Complaint[]
  chatMessages            ChatMessage[]
  chatAttachments         ChatAttachment[]
  mutedChats              MutedChat[]
  notifications           Notification[]
  pushSubscriptions       PushSubscription[]
  liveSessions            LiveSession[]
  sessionAttendees        SessionAttendee[]
  systemSettings          SystemSettings[]
  auditLogs               AuditLog[]
  chatbotConversations    ChatbotConversation[]
  chatbotMessages         ChatbotMessage[]
  coursePrerequisites     CoursePrerequisite[]
  currentTerms            CurrentTerm[]
  courseSectionTAs        CourseSectionTA[]
  chatGroups              ChatGroup[]
  chatMembers             ChatMember[]
  groupChatMessages       GroupChatMessage[]
  systemBackups           SystemBackup[]
  enrollmentSuspensions   EnrollmentSuspension[]
  enrollmentCancellations EnrollmentCancellation[]
  programmeChanges        ProgrammeChange[]
  nameChangeRequests      NameChangeRequest[]
  roles                   Role[]
  userRoleAssignments     UserRoleAssignment[]
  userPermissionOverrides UserPermissionOverride[]
  loginLocks              LoginLock[]

  @@map("tenants")
}

// ============================================================================
// 1. USERS & AUTH
// ============================================================================

model User {
  id                        String     @id @default(cuid())
  tenantId                  String     @map("tenant_id")
  tenant                    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  odId                      String?    @map("od_id")
  email                     String
  firstName                 String     @map("first_name")
  lastName                  String     @map("last_name")
  password                  String
  role                      UserRole   @default(student)
  status                    UserStatus @default(Active)
  phone                     String?
  dateOfBirth               DateTime?  @map("date_of_birth")
  gender                    String?
  nationality               String?
  profilePicture            String?    @map("profile_picture")
  activated                 Boolean    @default(false)
  emailVerified             Boolean    @default(false) @map("email_verified")
  lastLogin                 DateTime?  @map("last_login")
  // Firebase Cloud Messaging device token. Set on login when the browser /
  // Capacitor client successfully obtains a token from FCM; cleared on logout
  // or when the token is reported invalid by the FCM API. Optional —
  // notifications still work over Socket.io + DB without a token.
  fcmToken                  String?    @map("fcm_token")
  fcmTokenAt                DateTime?  @map("fcm_token_at")
  // Generic device-binding fields, decoupled from FCM. Set when the user
  // clicks "Register Device" in their profile so attendance scans can be
  // tied back to a specific browser/app install. Independent of notification
  // permission — works even if push is blocked.
  registeredDeviceId        String?    @map("registered_device_id")
  registeredDeviceLabel     String?    @map("registered_device_label")
  deviceRegisteredAt        DateTime?  @map("device_registered_at")
  // Re-registration release control (Attendance Documentation §3.5.3.5).
  // deviceReleaseAt: when the student may register a NEW device after an admin
  // grants a release. future = 48h normal-release cooldown (manual attendance).
  deviceReleaseAt           DateTime?  @map("device_release_at")
  deviceReleaseType         String?    @map("device_release_type")
  deviceReleasedById        String?    @map("device_released_by_id")
  // Cryptographic device-binding public key (ECDSA P-256). Native app stores
  // the Secure Enclave / StrongBox key; PWA stores a mock (unverifiable).
  registeredDevicePublicKey String?    @map("registered_device_public_key")
  // Phase 10 — admin-only contact + notes. Both surface in UserEditPage but
  // are not visible to the user themselves.
  secondaryEmail            String?    @map("secondary_email")
  adminNotes                String?    @map("admin_notes")
  // Plan 4 Phase 8 — academic advisor (FCDS Article 12). The flag marks a
  // professor as available for advising (UI hint, optional). The FK on a
  // student row points at the assigned advisor's User.id; the referenced
  // user must have role=professor (validated at write time, not in schema).
  isAcademicAdvisor         Boolean    @default(false) @map("is_academic_advisor")
  // Per-student "registrations need advisor approval" flag. Defaults to
  // false — most students register straight to SA. Admin flips this on
  // for the subset that needs an extra advisor gate. Effective gate is
  // (advisorPolicy.requireAdvisorApproval AND user.requiresAdvisorApproval).
  requiresAdvisorApproval   Boolean    @default(false) @map("requires_advisor_approval")
  academicAdvisorId         String?    @map("academic_advisor_id")
  academicAdvisor           User?      @relation("AcademicAdvisor", fields: [academicAdvisorId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  advisees                  User[]     @relation("AcademicAdvisor")
  // Soft-delete: set on admin DELETE, filtered out of list/login lookups.
  // Row stays in DB so FK history (audit logs, transcripts, payslips) survives.
  deletedAt                 DateTime?  @map("deleted_at")
  // Plan 5 — reversible administrative pause. Distinct from `deletedAt`
  // (permanent removal). Login handler surfaces a per-reason message:
  // "Your account is inactive: <reason>. Contact administration..."
  suspendedAt               DateTime?  @map("suspended_at")
  suspendedReason           String?    @map("suspended_reason")
  // Stripe Customer ID — created lazily on first Stripe Checkout Session
  // for this user. Lets future flows attach a saved card / look up history
  // without re-creating the customer record. Nullable so legacy rows + users
  // who never pay don't have to be backfilled.
  stripeCustomerId          String?    @map("stripe_customer_id")
  createdAt                 DateTime   @default(now()) @map("created_at")
  updatedAt                 DateTime   @updatedAt @map("updated_at")

  // §1 Auth relations
  address           UserAddress?
  emergencyContact  EmergencyContact?
  settings          UserSettings?
  sessions          Session[]
  verificationCodes VerificationCode[]
  resetTokens       ResetToken[]
  refreshTokens     RefreshToken[]
  // Phase 6 — dynamic role assignments. User.role (above) is the denormalized
  // primary role used for fast filtering and JWT claims; this list is the
  // source-of-truth for permission enforcement (a user can hold multiple roles).
  roleAssignments   UserRoleAssignment[]

  // §2 Academic
  academicProfile   AcademicProfile?
  transcriptCourses TranscriptCourse[]
  semesterGpas      SemesterGpa[]

  // §3 Courses (instructor)
  instructedSections            CourseSection[]   @relation("SectionInstructor")
  courseSchedules               CourseSchedule[]
  taAssignments                 CourseSectionTA[] @relation("TAAssignments")
  taAssignmentsGranted          CourseSectionTA[] @relation("TAAssigner")
  defaultForCoursesAsInstructor Course[]          @relation("CourseDefaultInstructor")
  defaultForCoursesAsTa         Course[]          @relation("CourseDefaultTa")

  // §4 Registrations
  registrations             Registration[]
  registrationApprovals     Registration[]     @relation("RegistrationApprover")
  registrationSwaps         RegistrationSwap[] @relation("SwapUser")
  registrationSwapProcessed RegistrationSwap[] @relation("SwapProcessor")

  // §5 Course Content
  studentProgress   StudentProgress[]
  uploadedMaterials CourseMaterial[]  @relation("MaterialUploader")
  lectureProgress   LectureProgress[]

  // §6 Assignments
  assignmentSubmissions AssignmentSubmission[]
  gradedSubmissions     AssignmentSubmission[] @relation("SubmissionGrader")
  proposedSubmissions   AssignmentSubmission[] @relation("SubmissionProposer")
  approvedSubmissions   AssignmentSubmission[] @relation("SubmissionApprover")

  // §7 Quizzes
  quizSubmissions QuizSubmission[]
  createdQuizzes  Quiz[]           @relation("QuizCreator")

  // §8 Gradebook
  gradebookEntries      GradebookEntry[]      @relation("GradebookStudent")
  gradedEntries         GradebookEntry[]      @relation("GradebookGrader")
  // Plan 7 Phase 1 — professor confirmation of final grades.
  confirmedGradeEntries GradebookEntry[]      @relation("GradebookConfirmer")
  releasedGradeEntries  GradebookEntry[]      @relation("GradebookReleaser")
  // Plan 7 Phase 4 — generic form composer.
  formsCreated          Form[]                @relation("FormCreator")
  formResponses         FormResponse[]        @relation("FormRespondent")
  // Plan 7 Phase 6 — financial aid.
  financialAidRequests  FinancialAidRequest[] @relation("FinancialAidApplicant")
  financialAidReviews   FinancialAidRequest[] @relation("FinancialAidReviewer")

  // §9 Attendance
  attendanceSessions AttendanceSession[]
  attendanceRecords  AttendanceRecord[]
  cheatingFlagsUser  CheatingFlag[]      @relation("CheatingFlagUser")
  cheatingFlagsOther CheatingFlag[]      @relation("CheatingFlagOther")
  studentEnrollments StudentEnrollment[]
  attendanceExcuses  AttendanceExcuse[]  @relation("ExcuseUser")
  excuseReviews      AttendanceExcuse[]  @relation("ExcuseReviewer")

  // §10 Payments
  studentAccount           StudentAccount?
  invoices                 Invoice[]
  transactions             Transaction[]
  paymentMethods           PaymentMethod[]
  serviceRequests          ServiceRequest[]
  serviceRequestsProcessed ServiceRequest[] @relation("ServiceRequestProcessor")

  // §11 Student Affairs
  supportRequests          SupportRequest[]
  assignedSupportRequests  SupportRequest[] @relation("SupportRequestAssignee")
  processedSupportRequests SupportRequest[] @relation("SupportRequestProcessor")
  announcements            Announcement[]   @relation("AnnouncementAuthor")
  complaints               Complaint[]      @relation("Complainant")
  complaintTargets         Complaint[]      @relation("ComplaintTarget")
  complaintResolutions     Complaint[]      @relation("ComplaintResolver")
  processedComplaints      Complaint[]      @relation("ComplaintProcessor")

  // §12 Chat & Notifications
  chatMessages         ChatMessage[]
  mutedChats           MutedChat[]
  notifications        Notification[]
  pushSubscriptions    PushSubscription[]
  chatMemberships      ChatMember[]
  groupMessages        GroupChatMessage[] @relation("GroupMessageSender")
  deletedGroupMessages GroupChatMessage[] @relation("GroupMessageDeleter")

  // §13 Live Sessions
  hostedSessions   LiveSession[]     @relation("SessionHost")
  sessionAttendees SessionAttendee[]

  // §14 Admin
  auditLogs     AuditLog[]     @relation("AuditPerformer")
  systemBackups SystemBackup[] @relation("BackupCreator")

  // §15 Chatbot
  chatbotConversations ChatbotConversation[]

  // New models
  currentTermSet CurrentTerm[] @relation("CurrentTermSetter")

  // §16 Name Change Requests
  nameChangeRequests  NameChangeRequest[]
  reviewedNameChanges NameChangeRequest[] @relation("NameChangeReviewer")

  // Plan 4 Phase 6 — enrollment workflow back-references. Each model has a
  // separate relation alias so a single user can be both requester and
  // reviewer (for non-self approvals).
  suspensions                  EnrollmentSuspension[]   @relation("SuspensionUser")
  reviewedSuspensions          EnrollmentSuspension[]   @relation("SuspensionReviewer")
  cancellations                EnrollmentCancellation[] @relation("CancellationUser")
  reviewedCancellations        EnrollmentCancellation[] @relation("CancellationReviewer")
  programmeChanges             ProgrammeChange[]        @relation("ProgrammeChangeUser")
  reviewedProgrammeChanges     ProgrammeChange[]        @relation("ProgrammeChangeReviewer")
  // Plan 4 Phase 7 — mobility / auditor back-references.
  // Plan 4 Phase 8 — registrations the user (as advisor) has approved.
  advisorApprovedRegistrations Registration[]           @relation("RegistrationAdvisorApprover")

  // §10b Payroll
  employeeProfile    EmployeeProfile?
  payslips           Payslip[]        @relation("PayslipUser")
  payrollRunsCreated PayrollRun[]     @relation("PayrollRunner")

  // Plan 5 — per-user permission overrides, login locks, manual enrollments.
  permissionOverrides        UserPermissionOverride[] @relation("PermissionOverrideUser")
  createdPermissionOverrides UserPermissionOverride[] @relation("PermissionOverrideCreator")
  createdLoginLocks          LoginLock[]              @relation("LoginLockCreator")
  releasedLoginLocks         LoginLock[]              @relation("LoginLockReleaser")

  @@unique([tenantId, email])
  @@unique([tenantId, odId])
  @@index([tenantId])
  @@map("users")
}

model UserAddress {
  id       String  @id @default(cuid())
  tenantId String  @map("tenant_id")
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String  @unique @map("user_id")
  street   String?
  city     String?
  state    String?
  zipCode  String? @map("zip_code")
  country  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("user_addresses")
}

model EmergencyContact {
  id           String  @id @default(cuid())
  tenantId     String  @map("tenant_id")
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String  @unique @map("user_id")
  name         String
  relationship String?
  phone        String
  email        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("emergency_contacts")
}

model UserSettings {
  id                 String  @id @default(cuid())
  tenantId           String  @map("tenant_id")
  tenant             Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId             String  @unique @map("user_id")
  theme              String  @default("system")
  fontSize           Int     @default(16) @map("font_size")
  compactMode        Boolean @default(false) @map("compact_mode")
  notifEmail         Boolean @default(true) @map("notif_email")
  notifPush          Boolean @default(true) @map("notif_push")
  notifSms           Boolean @default(false) @map("notif_sms")
  notifAnnouncements Boolean @default(true) @map("notif_announcements")
  notifGrades        Boolean @default(true) @map("notif_grades")
  notifAssignments   Boolean @default(true) @map("notif_assignments")
  notifMessages      Boolean @default(true) @map("notif_messages")
  notifReminders     Boolean @default(true) @map("notif_reminders")
  showEmail          Boolean @default(false) @map("show_email")
  showPhone          Boolean @default(false) @map("show_phone")
  showProfile        Boolean @default(true) @map("show_profile")
  allowMessages      Boolean @default(true) @map("allow_messages")
  language           String  @default("en")
  timezone           String  @default("Africa/Cairo")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("user_settings")
}

model Session {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  token     String
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, token])
  @@index([tenantId])
  @@map("sessions")
}

model VerificationCode {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  email     String
  code      String
  purpose   String   @default("email_verification")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("verification_codes")
}

model ResetToken {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  token     String
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, token])
  @@index([tenantId])
  @@map("reset_tokens")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  token     String
  revoked   Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, token])
  @@index([userId])
  @@index([expiresAt])
  @@index([tenantId])
  @@map("refresh_tokens")
}

// ============================================================================
// 2. ACADEMIC RECORDS
// ============================================================================

model AcademicProfile {
  id                  String        @id @default(cuid())
  tenantId            String        @map("tenant_id")
  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId              String        @unique @map("user_id")
  program             String?
  major               String?
  minor               String?
  studentId           String?       @map("student_id")
  department          String?
  level               Int?
  creditHours         Int           @default(0) @map("credit_hours")
  completedCredits    Int           @default(0) @map("completed_credits")
  enrollmentDate      DateTime?     @map("enrollment_date")
  expectedGraduation  DateTime?     @map("expected_graduation")
  standing            UserStanding? @default(Freshman)
  status              UserStatus?   @default(Active)
  advisorName         String?       @map("advisor_name")
  advisorEmail        String?       @map("advisor_email")
  gpa                 Decimal       @default(0.00) @db.Decimal(3, 2)
  totalCredits        Int           @default(0) @map("total_credits")
  creditsThisSemester Int           @default(0) @map("credits_this_semester")
  // Plan 4 Phase 5 — recomputed by transcript-cascade after every grade event.
  //   academicStanding: 'good' | 'warning' | 'probation' | 'dismissed' (FCDS Article 19)
  //   honorsEligible:   'none' | 'honors' | 'high_honors' | 'disqualified'  (Article 22)
  academicStanding    String?       @map("academic_standing")
  honorsEligible      String?       @map("honors_eligible")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, studentId])
  @@index([tenantId])
  @@map("academic_profiles")
}

model Semester {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code         String?
  name         String
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  academicYear String?   @map("academic_year")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  transcriptCourses   TranscriptCourse[]
  semesterGpas        SemesterGpa[]
  registrationPeriods RegistrationPeriod[]
  invoices            Invoice[]
  currentTerm         CurrentTerm?

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("semesters")
}

model TranscriptCourse {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String   @map("user_id")
  semesterId    String   @map("semester_id")
  courseCode    String   @map("course_code")
  courseTitle   String   @map("course_title")
  credits       Int
  grade         String
  qualityPoints Decimal  @default(0.0) @map("quality_points") @db.Decimal(3, 1)
  // Plan 22 retake support — successive attempts for the same
  // (user, semester, courseCode) triple bump this so each release
  // creates a NEW row instead of editing the previous one. Default 1
  // covers every legacy row; release endpoint allocates max+1.
  attemptNumber Int      @default(1) @map("attempt_number")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  semester   Semester         @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  breakdowns GradeBreakdown[]

  @@unique([userId, semesterId, courseCode, attemptNumber])
  @@index([userId, semesterId])
  @@index([tenantId])
  @@map("transcript_courses")
}

model GradeBreakdown {
  id                 String @id @default(cuid())
  tenantId           String @map("tenant_id")
  tenant             Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transcriptCourseId String @map("transcript_course_id")
  categoryTitle      String @map("category_title")
  componentName      String @map("component_name")
  grade              String
  weight             String
  contribution       String

  transcriptCourse TranscriptCourse @relation(fields: [transcriptCourseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("grade_breakdowns")
}

model SemesterGpa {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String   @map("user_id")
  semesterId    String   @map("semester_id")
  gpa           Decimal  @db.Decimal(3, 2)
  credits       Int
  cumulativeGpa Decimal  @default(0.00) @map("cumulative_gpa") @db.Decimal(3, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  semester Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  @@unique([userId, semesterId])
  @@index([tenantId])
  @@map("semester_gpas")
}

// ============================================================================
// 3. DEPARTMENTS & COURSES
// ============================================================================

model Department {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code              String
  name              String
  description       String?
  headId            String?  @map("head_id")
  // Plan 4 Phase 2 follow-up — program-level fields folded into Department
  // (programs and departments unified). Defaults match FCDS: 140 cr total
  // = 106 compulsory + 24 elective + 10 university requirements (the
  // remaining 10 live on the student's record, not the department).
  totalCredits      Int      @default(140) @map("total_credits")
  compulsoryCredits Int      @default(106) @map("compulsory_credits")
  electiveCredits   Int      @default(24) @map("elective_credits")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  courses            Course[]
  // Cross-listed courses (M:N via CourseDepartment). Lets a department
  // surface courses owned by another department in its student catalog.
  crossListedCourses CourseDepartment[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("departments")
}

// Plan 4 Phase 2 — academic programs (FCDS Article 1) were merged into the
// `departments` table per a follow-up cleanup. The 6 FCDS programs now live
// as 6 department rows with codes 01–06 alongside the legacy department
// rows; migration 20260501110000 dropped the separate `programs` table.

model Course {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code                String
  title               String
  credits             Int
  departmentId        String?  @map("department_id")
  description         String?
  level               Int?
  syllabus            Json?
  maxStudents         Int      @default(30) @map("max_students")
  lectureOnly         Boolean  @default(false) @map("lecture_only")
  isActive            Boolean  @default(true) @map("is_active")
  semester            String?
  // Plan 4 Phase 2 — language (Article 7) + category (Articles 30, 31).
  // language: 'en' | 'ar' — drives the language chip on student catalog cards.
  // category: 'university' | 'faculty_compulsory' | 'faculty_elective' |
  //           'program_compulsory' | 'program_elective' | 'training' | null.
  // (Programs were merged into departments; use `departmentId` for the
  //  per-course program/department affiliation.)
  language            String   @default("en")
  category            String?
  // Default instructor + TA for the course. Sections inherit them on
  // creation unless the admin picks someone else per section. ON DELETE
  // SET NULL so deleting the user clears the default but leaves the
  // course intact.
  defaultInstructorId String?  @map("default_instructor_id")
  defaultTaId         String?  @map("default_ta_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  department             Department?            @relation(fields: [departmentId], references: [id])
  defaultInstructor      User?                  @relation("CourseDefaultInstructor", fields: [defaultInstructorId], references: [id], onDelete: SetNull)
  defaultTa              User?                  @relation("CourseDefaultTa", fields: [defaultTaId], references: [id], onDelete: SetNull)
  sections               CourseSection[]
  registrations          Registration[]
  materials              CourseMaterial[]
  studentProgress        StudentProgress[]
  remarks                CourseRemark[]
  assignments            Assignment[]
  quizzes                Quiz[]
  gradebookEntries       GradebookEntry[]
  assignmentSubmissions  AssignmentSubmission[]
  quizSubmissions        QuizSubmission[]
  attendanceSessions     AttendanceSession[]
  attendanceRecords      AttendanceRecord[]
  courseSchedules        CourseSchedule[]
  studentEnrollments     StudentEnrollment[]
  liveSessions           LiveSession[]
  chatMessages           ChatMessage[]
  mutedChats             MutedChat[]
  lectures               Lecture[]
  prereqFor              CoursePrerequisite[]   @relation("CoursePrereqs")
  prerequisites          CoursePrerequisite[]   @relation("PrereqOf")
  // Multi-department cross-listing — see migration 20260520000000. The
  // single `departmentId` above remains the PRIMARY / owning department;
  // these rows are PURELY ADDITIVE extensions that broaden visibility.
  // Student access = (course.departmentId == student.dept)
  //                  OR (student.dept IN crossListedDepartments).
  crossListedDepartments CourseDepartment[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("courses")
}

// Many-to-many cross-listing between Course and Department. A course may
// belong to one PRIMARY department (Course.departmentId) AND be cross-listed
// to N additional departments via rows here — the cross-listed departments
// can see the course in their student catalog without needing a duplicate
// Course row per department.
model CourseDepartment {
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId     String   @map("course_id")
  departmentId String   @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")

  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([courseId, departmentId])
  @@index([courseId])
  @@index([departmentId])
  @@index([tenantId])
  @@map("course_departments")
}

model CourseSection {
  id             String      @id @default(cuid())
  tenantId       String      @map("tenant_id")
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId       String      @map("course_id")
  sectionId      String      @map("section_id")
  type           SectionType
  instructorId   String?     @map("instructor_id")
  instructorName String?     @map("instructor_name")
  location       String?
  room           String?
  // FK → BssidLocation. Nullable so existing rows survive the migration;
  // the API enforces "required on create" for new sections via
  // assertSectionHallValid in the registration server.
  hallId         String?     @map("hall_id")
  semester       String?
  year           Int?
  capacity       Int         @default(30)
  enrolled       Int         @default(0)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  course             Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  hall               BssidLocation?      @relation("SectionHall", fields: [hallId], references: [id], onDelete: SetNull)
  instructor         User?               @relation("SectionInstructor", fields: [instructorId], references: [id])
  slots              SectionSlot[]
  registrations      Registration[]
  gradebookEntries   GradebookEntry[]    @relation("GradebookSectionRef")
  attendanceSessions AttendanceSession[]
  courseSchedules    CourseSchedule[]
  swapsTo            RegistrationSwap[]  @relation("SwapToSection")
  lectures           Lecture[]
  taAssignments      CourseSectionTA[]
  chatGroup          ChatGroup?
  // Plan 4 Phase 7 — auditor enrollments (Article 24).

  @@unique([courseId, sectionId])
  @@index([tenantId])
  @@map("course_sections")
}

model SectionSlot {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sectionId String    @map("section_id")
  day       DayOfWeek
  startTime String    @map("start_time")
  endTime   String    @map("end_time")
  room      String?
  createdAt DateTime  @default(now()) @map("created_at")

  section CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("section_slots")
}

// ============================================================================
// 4. REGISTRATIONS
// ============================================================================

model Registration {
  id                  String             @id @default(cuid())
  tenantId            String             @map("tenant_id")
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId              String             @map("user_id")
  courseId            String             @map("course_id")
  sectionId           String             @map("section_id")
  status              RegistrationStatus @default(pending)
  approvedById        String?            @map("approved_by_id")
  pendingReason       String?            @map("pending_reason")
  pendingNote         String?            @map("pending_note")
  // Plan 4 Phase 7 — internal auditor flag (Article 24). When true, the
  // course doesn't count toward credit-hour totals or GPA.
  isAudit             Boolean            @default(false) @map("is_audit")
  // Plan 4 Phase 8 — academic-advisor approval gate (Article 12). When the
  // policy requires advisor approval, registrations land in `pending` with
  // `pendingReason='advisor_approval'`; the assigned advisor flips
  // `advisorApproved=true` from the Advisees queue.
  advisorApproved     Boolean            @default(false) @map("advisor_approved")
  advisorApprovedAt   DateTime?          @map("advisor_approved_at")
  advisorApprovedById String?            @map("advisor_approved_by_id")
  registeredAt        DateTime           @default(now()) @map("registered_at")
  droppedAt           DateTime?          @map("dropped_at")
  isActive            Boolean            @default(true) @map("is_active")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section           CourseSection      @relation(fields: [sectionId], references: [id])
  approvedBy        User?              @relation("RegistrationApprover", fields: [approvedById], references: [id])
  advisorApprovedBy User?              @relation("RegistrationAdvisorApprover", fields: [advisorApprovedById], references: [id])
  swaps             RegistrationSwap[]

  @@unique([userId, sectionId])
  @@index([userId, status])
  @@index([tenantId])
  @@map("registrations")
}

model RegistrationPeriod {
  id              String                   @id @default(cuid())
  tenantId        String                   @map("tenant_id")
  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  semesterId      String?                  @map("semester_id")
  semester        String?
  type            String?
  status          RegistrationPeriodStatus @default(upcoming)
  startDate       DateTime                 @map("start_date")
  endDate         DateTime                 @map("end_date")
  isActive        Boolean                  @default(false) @map("is_active")
  addDropDeadline DateTime?                @map("add_drop_deadline")
  lateDeadline    DateTime?                @map("late_deadline")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  semesterRef Semester? @relation(fields: [semesterId], references: [id])

  @@index([tenantId])
  @@map("registration_periods")
}

model RegistrationSwap {
  id                 String             @id @default(cuid())
  tenantId           String             @map("tenant_id")
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId             String             @map("user_id")
  fromRegistrationId String             @map("from_registration_id")
  toSectionId        String             @map("to_section_id")
  status             RegistrationStatus @default(pending)
  processedById      String?            @map("processed_by_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user             User          @relation("SwapUser", fields: [userId], references: [id])
  fromRegistration Registration  @relation(fields: [fromRegistrationId], references: [id])
  toSection        CourseSection @relation("SwapToSection", fields: [toSectionId], references: [id])
  processedBy      User?         @relation("SwapProcessor", fields: [processedById], references: [id])

  @@index([tenantId])
  @@map("registration_swaps")
}

// ============================================================================
// 5. COURSE CONTENT
// ============================================================================

model CourseMaterial {
  id            String       @id @default(cuid())
  tenantId      String       @map("tenant_id")
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId      String       @map("course_id")
  sectionId     String?      @map("section_id")
  category      String       @default("lectures")
  title         String
  type          MaterialType
  size          String?
  duration      String?
  url           String?
  filePath      String?      @map("file_path")
  fileName      String?      @map("file_name")
  originalName  String?      @map("original_name")
  uploadedById  String?      @map("uploaded_by_id")
  downloadCount Int          @default(0) @map("download_count")
  isPublished   Boolean      @default(true) @map("is_published")
  isNew         Boolean      @default(true) @map("is_new")
  views         Int          @default(0)
  uploadedAt    DateTime     @default(now()) @map("uploaded_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  course     Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  uploadedBy User?             @relation("MaterialUploader", fields: [uploadedById], references: [id])
  progress   StudentProgress[]

  @@index([tenantId])
  @@map("course_materials")
}

model StudentProgress {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String    @map("user_id")
  courseId     String    @map("course_id")
  materialId   String?   @map("material_id")
  materialType String?   @map("material_type")
  completed    Boolean   @default(false)
  progress     Decimal   @default(0) @db.Decimal(5, 2)
  position     Int       @default(0)
  duration     Int       @default(0)
  completedAt  DateTime? @map("completed_at")
  lastViewedAt DateTime? @map("last_viewed_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  material CourseMaterial? @relation(fields: [materialId], references: [id])

  @@unique([userId, materialId])
  @@index([tenantId])
  @@map("student_progress")
}

model CourseRemark {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId  String   @map("course_id")
  userId    String?  @map("user_id")
  title     String
  content   String
  important Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("course_remarks")
}

model Lecture {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId      String    @map("course_id")
  sectionId     String?   @map("section_id")
  lectureNumber Int       @map("lecture_number")
  title         String
  topic         String?
  scheduledFor  DateTime? @map("scheduled_for")
  recordingUrl  String?   @map("recording_url")
  slidesUrl     String?   @map("slides_url")
  notes         String?
  isPublished   Boolean   @default(true) @map("is_published")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  course   Course            @relation(fields: [courseId], references: [id])
  section  CourseSection?    @relation(fields: [sectionId], references: [id])
  progress LectureProgress[]

  @@index([tenantId])
  @@map("lectures")
}

model LectureProgress {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String    @map("user_id")
  lectureId      String    @map("lecture_id")
  watchedSeconds Int       @default(0) @map("watched_seconds")
  completed      Boolean   @default(false)
  lastWatchedAt  DateTime? @map("last_watched_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@unique([userId, lectureId])
  @@index([tenantId])
  @@map("lecture_progress")
}

// ============================================================================
// 6. ASSIGNMENTS & SUBMISSIONS
// ============================================================================

model Assignment {
  id                String           @id @default(cuid())
  tenantId          String           @map("tenant_id")
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId          String           @map("course_id")
  title             String
  description       String?
  dueDate           DateTime         @map("due_date")
  maxScore          Float            @default(100) @map("max_score")
  weight            Float?
  status            AssignmentStatus @default(active)
  allowLate         Boolean          @default(false) @map("allow_late")
  // Score change applied (or shown to the student) when the deadline passes
  // without a submission. Negative number = penalty (default -2). Set to 0 to
  // disable. Editable per-assignment by professors / admin.
  latePenalty       Float            @default(-2) @map("late_penalty")
  // Grace period (hours) AFTER dueDate before an unsubmitted assignment is
  // flagged "missing" on the student page. Default 0 = flagged the moment
  // the deadline passes. Lets the staff hold the missing-state for a few
  // hours so a student who submits 30 min late doesn't show as missing.
  missingAfterHours Int              @default(0) @map("missing_after_hours")
  instructions      String?
  attachments       String[]         @default([])
  allowedFileTypes  String[]         @default([]) @map("allowed_file_types")
  maxSubmissions    Int              @default(3) @map("max_submissions")
  // Optional audience targeting. Empty = whole class (default).
  // Non-empty narrows the assignment to the listed user ids (FCDS Plan 5).
  audienceUserIds   String[]         @default([]) @map("audience_user_ids")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  course      Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  @@index([tenantId])
  @@map("assignments")
}

model AssignmentSubmission {
  id               String           @id @default(cuid())
  tenantId         String           @map("tenant_id")
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignmentId     String           @map("assignment_id")
  userId           String           @map("user_id")
  courseId         String           @map("course_id")
  filePath         String?          @map("file_path")
  fileName         String?          @map("file_name")
  originalFileName String?          @map("original_file_name")
  content          String?
  submittedAt      DateTime         @default(now()) @map("submitted_at")
  isLate           Boolean          @default(false) @map("is_late")
  attemptNumber    Int              @default(1) @map("attempt_number")
  status           SubmissionStatus @default(submitted)
  score            Float?
  feedback         String?
  gradedById       String?          @map("graded_by_id")
  gradedAt         DateTime?        @map("graded_at")
  proposedScore    Float?           @map("proposed_score")
  proposedById     String?          @map("proposed_by_id")
  approvedById     String?          @map("approved_by_id")
  approvedAt       DateTime?        @map("approved_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course     @relation(fields: [courseId], references: [id])
  gradedBy   User?      @relation("SubmissionGrader", fields: [gradedById], references: [id])
  proposedBy User?      @relation("SubmissionProposer", fields: [proposedById], references: [id])
  approvedBy User?      @relation("SubmissionApprover", fields: [approvedById], references: [id])

  @@unique([assignmentId, userId])
  @@index([assignmentId, userId])
  @@index([tenantId])
  @@map("assignment_submissions")
}

// ============================================================================
// 7. QUIZZES
// ============================================================================

model Quiz {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId        String    @map("course_id")
  title           String
  description     String?
  timeLimit       Int       @default(30) @map("time_limit")
  maxAttempts     Int       @default(1) @map("max_attempts")
  passingScore    Float?    @map("passing_score")
  isPublished     Boolean   @default(false) @map("is_published")
  dueDate         DateTime? @map("due_date")
  // `startsAt` is the global timer anchor. Once it passes, every student's
  // remaining time = (startsAt + timeLimit) - now. NULL = unscheduled (the
  // quiz is open as soon as it's published). FCDS uses this to enforce
  // "everyone takes the quiz at the same wall-clock window".
  // Stored as TIMESTAMPTZ — preserves the absolute instant regardless of
  // database session timezone. See migration 20260503300000.
  startsAt        DateTime? @map("starts_at") @db.Timestamptz(6)
  // Optional total-points override. NULL = derive from Σ question.points.
  totalPoints     Float?    @map("total_points")
  createdById     String?   @map("created_by_id")
  // Optional audience targeting. Empty = whole class (default).
  // Non-empty narrows the quiz to the listed user ids (FCDS Plan 5).
  audienceUserIds String[]  @default([]) @map("audience_user_ids")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy   User?            @relation("QuizCreator", fields: [createdById], references: [id])
  questions   QuizQuestion[]
  submissions QuizSubmission[]

  @@index([tenantId])
  @@map("quizzes")
}

model QuizQuestion {
  id            String           @id @default(cuid())
  tenantId      String           @map("tenant_id")
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quizId        String           @map("quiz_id")
  type          QuizQuestionType @default(mcq)
  text          String
  points        Float            @default(1)
  options       Json?
  correctAnswer String?          @map("correct_answer")
  sortOrder     Int              @default(0) @map("sort_order")
  createdAt     DateTime         @default(now()) @map("created_at")

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([tenantId])
  @@map("quiz_questions")
}

model QuizSubmission {
  id          String               @id @default(cuid())
  tenantId    String               @map("tenant_id")
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quizId      String               @map("quiz_id")
  userId      String               @map("user_id")
  courseId    String               @map("course_id")
  startedAt   DateTime             @default(now()) @map("started_at")
  submittedAt DateTime?            @map("submitted_at")
  score       Float?
  maxPoints   Float                @default(0) @map("max_points")
  status      QuizSubmissionStatus @default(in_progress)
  attempt     Int                  @default(1)
  createdAt   DateTime             @default(now()) @map("created_at")

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  course  Course       @relation(fields: [courseId], references: [id])
  answers QuizAnswer[]

  @@unique([quizId, userId, attempt])
  @@index([tenantId])
  @@map("quiz_submissions")
}

model QuizAnswer {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submissionId String   @map("submission_id")
  questionId   String   @map("question_id")
  answer       String?  @map("user_answer")
  isCorrect    Boolean? @map("is_correct")
  pointsEarned Float    @default(0) @map("points_earned")
  createdAt    DateTime @default(now()) @map("created_at")

  submission QuizSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   QuizQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("quiz_answers")
}

// ============================================================================
// 8. GRADEBOOK
// ============================================================================

model GradebookEntry {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId      String    @map("course_id")
  sectionId     String?   @map("section_id")
  studentId     String    @map("student_id")
  component     String?
  score         Decimal?  @db.Decimal(5, 2)
  maxScore      Decimal   @default(100) @map("max_score") @db.Decimal(5, 2)
  letterGrade   String?   @map("letter_grade")
  gradePoints   Float?    @map("grade_points")
  isFinal       Boolean   @default(false) @map("is_final")
  comments      String?
  gradedById    String?   @map("graded_by_id")
  // Plan 7 Phase 1 — professor confirmation gate. When isFinal=true rows are
  // created, transcript ripple is skipped until confirmedById is non-null.
  // Backend auto-reopens (sets confirmedById back to null) when a related
  // breakdown is edited after confirmation, so the professor can re-review.
  confirmedById String?   @map("confirmed_by_id")
  confirmedAt   DateTime? @map("confirmed_at")
  // Plan 22 follow-up — Confirm vs Release split. confirmedAt = letter is
  // computed, visible on prof gradebook + student's Current Semester view.
  // releasedAt = prof explicitly fired the transcript cascade, the course
  // is now on the official transcript and disappears from Current Semester.
  releasedById  String?   @map("released_by_id")
  releasedAt    DateTime? @map("released_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section     CourseSection? @relation("GradebookSectionRef", fields: [sectionId], references: [id])
  student     User           @relation("GradebookStudent", fields: [studentId], references: [id], onDelete: Cascade)
  gradedBy    User?          @relation("GradebookGrader", fields: [gradedById], references: [id])
  confirmedBy User?          @relation("GradebookConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull)
  releasedBy  User?          @relation("GradebookReleaser", fields: [releasedById], references: [id], onDelete: SetNull)

  @@unique([courseId, studentId, component])
  @@index([confirmedById])
  @@index([releasedById])
  @@index([tenantId])
  @@map("gradebook_entries")
}

