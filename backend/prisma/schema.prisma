// ============================================================================
// 14. ADMIN SYSTEM
// ============================================================================

model SystemSettings {
  id                          String    @id @default(cuid())
  tenantId                    String    @unique @map("tenant_id")
  tenant                      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  maintenanceMode             Boolean   @default(false) @map("maintenance_mode")
  maintenanceMessage          String    @default("") @map("maintenance_message")
  registrationEnabled         Boolean   @default(true) @map("registration_enabled")
  // When true, EVERY student registration is routed through SA review
  // before becoming active. When false (default per owner directive
  // 2026-05-17), regular registrations auto-approve; probation /
  // above-level / late-window / advisor-required cases ALWAYS force
  // pending regardless. Read by the registration handler.
  registrationGatekeepEnabled Boolean   @default(false) @map("registration_gatekeep_enabled")
  maxCreditsPerSemester       Int       @default(21) @map("max_credits_per_semester")
  minCreditsPerSemester       Int       @default(12) @map("min_credits_per_semester")
  gradeSubmissionDeadline     DateTime? @map("grade_submission_deadline")
  currentSemester             String    @default("Fall 2025") @map("current_semester")
  academicYear                String    @default("2025-2026") @map("academic_year")
  emailNotifications          Boolean   @default(true) @map("email_notifications")
  smsNotifications            Boolean   @default(false) @map("sms_notifications")
  backupFrequency             String    @default("daily") @map("backup_frequency")
  sessionTimeoutMinutes       Int       @default(30) @map("session_timeout_minutes")
  passwordMinLength           Int       @default(8) @map("password_min_length")
  passwordRequireUppercase    Boolean   @default(true) @map("password_require_uppercase")
  passwordRequireNumber       Boolean   @default(true) @map("password_require_number")
  passwordRequireSpecial      Boolean   @default(false) @map("password_require_special")
  rolePermissions             Json?     @map("role_permissions")
  // Phase E — admin-configurable timetable policy:
  //   { workingDays: [day], slotMinutes, dayStart 'HH:MM', dayEnd 'HH:MM' }
  // Drives the auto-scheduler grid (see backend/lib/schedule-policy.js).
  schedulePolicy              Json?     @map("schedule_policy")
  // Phase 5 — admin-editable grading config. JSON shape (see backend/lib/
  // grading-rules.js for the canonical default + Zod schema):
  //   { scale: [{letter, minPercent, qualityPoints}], academicStanding: {...},
  //     credits: { min, max, graduationTotal } }
  // When null, callers fall back to DEFAULT_RULES.
  gradingRules                Json?     @map("grading_rules")
  // Phase 5 follow-up — real Course Configurations + Academic Calendar fields
  // (replaces the static info cards that previously rendered as mock UI).
  // courseCodePattern: regex validated on POST /api/admin/courses.
  // defaultSectionCapacity: default cap for new CourseSection rows.
  // requirePrerequisites: when true, registration flow blocks signup if prereqs unmet.
  // holidays: array of { date: 'YYYY-MM-DD', label: string } objects.
  courseCodePattern           String?   @default("^[A-Z]{2,4}[0-9]{3}$") @map("course_code_pattern")
  defaultSectionCapacity      Int       @default(30) @map("default_section_capacity")
  requirePrerequisites        Boolean   @default(true) @map("require_prerequisites")
  holidays                    Json?     @map("holidays")
  appName                     String?   @default("UniFlow") @map("app_name")
  language                    String?   @default("en") @map("language")
  timezone                    String?   @default("Africa/Cairo") @map("timezone")
  // Phase 9 — institution-wide currency. Three-letter ISO 4217 code. Used by
  // every monetary display in the admin Financials surface and the student
  // Payments page. Frontend reads it via the public /api/admin/system-settings
  // endpoint (no admin gate needed for the read because it's purely cosmetic).
  currency                    String    @default("EGP") @map("currency")
  // Phase 12 follow-up — institution-configurable academic structure.
  // numberOfAcademicLevels drives the level chips in AnnouncementComposer and
  // anywhere "Level 1, Level 2, …" needs to be enumerated. attendanceRules
  // stores the percentage thresholds for the warning / barred regulations
  // (mirrors the gradingRules JSON shape — JSON column so a tenant can
  // override the schema without a code change).
  numberOfAcademicLevels      Int       @default(4) @map("number_of_academic_levels")
  attendanceRules             Json?     @map("attendance_rules")
  // Phase 12 follow-up — admin-editable credit-hour caps. Replaces the nine
  // hardcoded constants that used to live in backend/lib/credit-limits.js.
  // JSON shape (see that file for the canonical default + Zod schema):
  //   { summer: 9, seniorBonus: 21, freshmanSecondChance: 19,
  //     freshmanSecondChanceMinGpa: 1.66, highGpa: 21, normal: 19,
  //     probation: 12, highGpaThreshold: 3.33, goodStandingThreshold: 2.0 }
  // When null, callers fall back to DEFAULT_CREDIT_POLICY.
  creditLimitPolicy           Json?     @map("credit_limit_policy")
  // Level progression — credit-hour thresholds that drive a student's academic
  // level. Shape:
  //   { thresholds: [{ level: 2, minCredits: 28 }, { level: 3, minCredits: 64 }, …] }
  // Level 1 is implicit at 0 credits. computeLevel(credits, policy) returns the
  // highest level whose minCredits is ≤ student's earned credits. When null,
  // callers fall back to DEFAULT_LEVEL_PROGRESSION in backend/lib/level-progression.js.
  levelProgression            Json?     @map("level_progression")
  // Plan 4 Phase 1 — graduation requirements (FCDS Article 8). Shape:
  //   { minTotalCredits: 140, minMainSemesters: 7, minCgpa: 2.0 }
  // When null, callers fall back to DEFAULT_GRADUATION_POLICY in
  // backend/lib/graduation-policy.js. Surfaced on the student transcript as an
  // "Eligible to graduate" pill.
  graduationPolicy            Json?     @map("graduation_policy")
  // Plan 4 Phase 1 — semester durations (FCDS Article 5). Shape:
  //   { fallWeeks: 15, springWeeks: 15, summerWeeks: 8 }
  // Future Phase 3 (registration / add-drop / withdrawal windows) will derive
  // its week-numbered windows from these values.
  semesterDurations           Json?     @map("semester_durations")
  // Plan 4 Phase 3 — late-reg / add-drop / withdrawal week ranges per main /
  // summer term (FCDS Articles 13, 14, 15). Shape (see backend/lib/
  // registration-windows.js for the Zod schema):
  //   { main: { lateRegistration: { startWeek, endWeek }, addDrop: {...},
  //     withdrawal: {...} }, summer: { same shape } }
  // When null, callers fall back to DEFAULT_WINDOWS_POLICY.
  windowsPolicy               Json?     @map("windows_policy")
  // Plan 4 Phase 4 — incomplete-grade policy (FCDS Article 17). Shape:
  //   { minTermWorkPercent: 60, maxIncompletesPerStudent: 3, makeupExamWindowDays: 7 }
  incompletePolicy            Json?     @map("incomplete_policy")
  // Plan 4 Phase 4 — course-repetition policy (FCDS Article 18). Shape:
  //   { retakesCountedForGpa: 8, countAllAttemptsBeyond: true,
  //     allowImprovementForProbation: true, maxGradeAfterRetake: 'C',
  //     maxGradeAppliesToFirstRetakeOnly: false, preserveOriginalIfHigher: true }
  repetitionPolicy            Json?     @map("repetition_policy")
  // Plan 4 Phase 5 — graduation-honors policy (FCDS Article 22). Shape:
  //   { maxMainSemesters: 8, perSemesterMinGpa: 3.0, cumulativeMinGpa: 3.4,
  //     highHonorsCumMinGpa: 3.8, disqualifyingGrades: ['F','FW','MW'],
  //     requireNoDisciplinary: true }
  honorsPolicy                Json?     @map("honors_policy")
  // Plan 4 Phase 6 — enrollment workflow caps (FCDS Articles 20, 21).
  //   { maxSuspensionsTotal: 4, maxConsecutive: 4,
  //     militaryWithdrawalCountsAgainstCap: false,
  //     reEnrollmentWithinSemesters: 4 }
  suspensionPolicy            Json?     @map("suspension_policy")
  // Plan 4 Phase 7 — Article 25 mobility / exchange caps + Article 24
  // visiting student per-term limits.
  //   { maxExternalPercentOfTotal: 0.25, includeInCgpa: true,
  //     visitingMaxPerMain: 12, visitingMaxPerSummer: 9 }
  mobilityPolicy              Json?     @map("mobility_policy")
  // Plan 4 Phase 8 — academic-advisor approval gate (Article 12).
  //   { requireAdvisorApproval: true, autoApproveBelowCredits: 0,
  //     gracePeriodHours: 0, restrictPickerToFlaggedProfessors: true }
  // When null, callers fall back to DEFAULT_ADVISOR_POLICY in
  // backend/lib/advisor-policy.js.
  advisorPolicy               Json?     @map("advisor_policy")
  // Plan 4 Phase 9 — Credit Hour Definition (FCDS Article 6).
  //   { lectureHoursPerCredit: 1, practicalHoursPerCredit: 2,
  //     appliedTrainingHoursPerCredit: 3, fieldTrainingHoursPerCredit: 4 }
  // When null, callers fall back to DEFAULT_CREDIT_HOUR_DEFINITION in
  // backend/lib/credit-hour-definition.js.
  creditHourDefinition        Json?     @map("credit_hour_definition")
  // Plan 6 — institution-wide brand + regulatory framework labels. Shape:
  //   { institutionName: 'FCDS, Alexandria University', productName: 'UniFlow',
  //     articleRefsVisible: false, regulatoryFramework: 'FCDS',
  //     brandedResetLabels: false }
  // Hides "FCDS Article N" prefixes from user-visible help text by default so
  // a deployment to a different institution doesn't ship the source-institution
  // branding. Read via the public /api/public-settings/institution endpoint.
  institutionConfig           Json?     @map("institution_config")
  // Plan 8 Phase 1 — Brand theme. Admin-customisable wordmark + 3-color
  // palette. Shape:
  //   { productName: 'UniFlow', brandPrimary: '#6A3FF4',
  //     brandSecondary: '#A855F7', brandAccent: '#7B5AFF',
  //     logoSegments: [{text:'Uni',color:'#6A3FF4'},{text:'Flow',color:'#FFFFFF'}] | null }
  // Read via the public /api/public-settings/brand endpoint; injected as
  // CSS custom properties on <html> by BrandContext.tsx so Tailwind utility
  // classes like `text-brand-primary` pick up the live value.
  brandConfig                 Json?     @map("brand_config")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("system_settings")
}

