// Halls / classrooms. Originally created to scope attendance QR validation
// (BSSID match); now also the canonical "room" reference for
// CourseSection.hallId so the timetable scheduler runs against real,
// capacity-bounded rooms.
model BssidLocation {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bssid     String
  location  String
  building  String?
  floor     String?
  room      String?
  name      String?
  capacity  Int      @default(30)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  sections CourseSection[] @relation("SectionHall")

  @@unique([tenantId, bssid])
  @@index([tenantId])
  @@map("bssid_locations")
}

model CourseSchedule {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId       String    @map("course_id")
  sectionId      String?   @map("section_id")
  instructorId   String?   @map("instructor_id")
  courseCode     String?   @map("course_code")
  instructorName String?   @map("instructor_name")
  dayOfWeek      DayOfWeek @map("day_of_week")
  startTime      String    @map("start_time")
  endTime        String    @map("end_time")
  room           String?
  building       String?
  semester       String?
  year           Int?
  validBssids    String[]  @default([]) @map("valid_bssids")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  course     Course         @relation(fields: [courseId], references: [id])
  section    CourseSection? @relation(fields: [sectionId], references: [id])
  instructor User?          @relation(fields: [instructorId], references: [id])

  @@index([tenantId])
  @@map("course_schedules")
}

model AttendanceSession {
  id                  String        @id @default(cuid())
  tenantId            String        @map("tenant_id")
  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId            String        @map("course_id")
  sectionId           String?       @map("section_id")
  instructorId        String?       @map("instructor_id")
  courseCode          String?       @map("course_code")
  courseName          String?       @map("course_name")
  qrToken             String?       @map("qr_token")
  expiresAt           DateTime?     @map("expires_at")
  validBssids         String[]      @default([]) @map("valid_bssids")
  // When non-empty, the session only counts attendance for the listed
  // user IDs — used for "special" one-off sessions where the rest of the
  // class shouldn't be auto-marked absent on end. Empty = full class.
  restrictedToUserIds String[]      @default([]) @map("restricted_to_user_ids")
  date                DateTime      @default(now())
  status              SessionStatus @default(active)
  roomOverride        String?       @map("room_override")
  bssidRequired       Boolean       @default(true) @map("bssid_required")
  startedAt           DateTime      @default(now()) @map("started_at")
  endedAt             DateTime?     @map("ended_at")
  isActive            Boolean       @default(true) @map("is_active")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  course     Course             @relation(fields: [courseId], references: [id])
  section    CourseSection?     @relation(fields: [sectionId], references: [id])
  instructor User?              @relation(fields: [instructorId], references: [id])
  records    AttendanceRecord[]
  flags      CheatingFlag[]
  excuses    AttendanceExcuse[]

  @@unique([tenantId, qrToken])
  @@index([courseId, date])
  @@index([tenantId])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id                 String              @id @default(cuid())
  tenantId           String              @map("tenant_id")
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId             String              @map("user_id")
  sessionId          String?             @map("session_id")
  courseId           String              @map("course_id")
  courseCode         String?             @map("course_code")
  courseName         String?             @map("course_name")
  date               DateTime            @default(now())
  status             AttendanceStatus
  markedAt           DateTime?           @default(now()) @map("marked_at")
  verificationMethod VerificationMethod? @default(qr_code) @map("verification_method")
  bssidVerified      Boolean?            @default(false) @map("bssid_verified")
  bssid              String?
  qrLatencyMs        Int?                @map("qr_latency_ms")
  deviceId           String?             @map("device_id")
  ipAddress          String?             @map("ip_address")
  deviceInfo         String?             @map("device_info")
  overridden         Boolean             @default(false)
  overrideReason     String?             @map("override_reason")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  session AttendanceSession? @relation(fields: [sessionId], references: [id])
  course  Course             @relation(fields: [courseId], references: [id])
  excuses AttendanceExcuse[]

  @@unique([sessionId, userId])
  @@index([userId, markedAt])
  @@index([tenantId])
  @@map("attendance_records")
}

model CheatingFlag {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String   @map("user_id")
  sessionId      String?  @map("session_id")
  reason         String
  otherStudentId String?  @map("other_student_id")
  flaggedAt      DateTime @default(now()) @map("flagged_at")
  reviewed       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  user         User               @relation("CheatingFlagUser", fields: [userId], references: [id])
  session      AttendanceSession? @relation(fields: [sessionId], references: [id])
  otherStudent User?              @relation("CheatingFlagOther", fields: [otherStudentId], references: [id])

  @@index([tenantId])
  @@map("cheating_flags")
}

model StudentEnrollment {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id")
  courseId   String   @map("course_id")
  courseCode String?  @map("course_code")
  createdAt  DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([tenantId])
  @@map("student_enrollments")
}

model AttendanceExcuse {
  id                 String        @id @default(cuid())
  tenantId           String        @map("tenant_id")
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId             String        @map("user_id")
  attendanceRecordId String?       @map("attendance_record_id")
  sessionId          String?       @map("session_id")
  reason             String
  evidenceUrl        String?       @map("evidence_url")
  status             RequestStatus @default(pending)
  reviewedById       String?       @map("reviewed_by_id")
  reviewedAt         DateTime?     @map("reviewed_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  user             User               @relation("ExcuseUser", fields: [userId], references: [id])
  attendanceRecord AttendanceRecord?  @relation(fields: [attendanceRecordId], references: [id])
  session          AttendanceSession? @relation(fields: [sessionId], references: [id])
  reviewedBy       User?              @relation("ExcuseReviewer", fields: [reviewedById], references: [id])

  @@index([tenantId])
  @@map("attendance_excuses")
}

