// ============================================================================
// §16 Dynamic Roles + RBAC (Phase 6)
// ============================================================================
// `Role` rows define a named permission set the admin can edit at runtime.
// 5 "system" roles (student/professor/ta/sa/admin) are seeded and cannot
// be deleted; admins can create additional custom roles for finer-grained
// access control. `User.role` enum is preserved as a denormalized primary
// role so existing `requireRole(...)` checks keep working without rewriting
// all 10 servers; the UserRoleAssignment join is the additive source-of-truth
// for permission enforcement.
//
// permissions JSON shape (per role):
//   {
//     "Student Management": { "read": true, "write": false, "delete": false },
//     "Course Management":  { "read": true, "write": true,  "delete": false },
//     ...
//   }

model Role {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  // Plan 5 — scope discriminator used by requireScope() in backend/lib/auth.js.
  // One of: 'financial' | 'it' | 'admin' | 'professor' | 'ta' | 'sa' |
  // 'student' | 'custom'. Admin is the implicit superset of the two admin
  // sub-scopes (financial/it). The `superuser` sub-role was removed in Plan 22.
  scope       String   @default("custom")
  description String?
  // System roles (the original 5 + 2 admin sub-scopes) cannot be renamed or
  // deleted. Custom roles created via the admin UI have isSystem = false.
  isSystem    Boolean  @default(false) @map("is_system")
  permissions Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  assignments UserRoleAssignment[]

  @@unique([tenantId, name])
  @@index([scope])
  @@index([tenantId])
  @@map("roles")
}

model UserRoleAssignment {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([tenantId])
  @@map("user_role_assignments")
}

// ============================================================================
// Plan 5 — Per-user permission overrides, login locks, manual enrollments
// ============================================================================
//
// These three tables underpin the admin power tools described in
// docs/plan-5.md. They are intentionally independent of the existing Role
// model so a future migration can drop the JSON `Role.permissions` blob
// without touching this surface.

// Per-user permission overrides — Notes line 70.
//
// NULL on can_read/can_write/can_delete means "inherit from role". Stored
// even when redundant with role values so the audit trail is unambiguous.
model UserPermissionOverride {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  category  String
  canRead   Boolean? @map("can_read")
  canWrite  Boolean? @map("can_write")
  canDelete Boolean? @map("can_delete")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User  @relation("PermissionOverrideUser", fields: [userId], references: [id], onDelete: Cascade)
  creator User? @relation("PermissionOverrideCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([userId, category])
  @@index([userId])
  @@index([tenantId])
  @@map("user_permission_overrides")
}

// Login lock targets + time windows — Notes line 108.
//
// `targetKind` is one of:
//   - 'user'       (targetId = User.id)
//   - 'level'      (targetId = academic level as text, e.g. '1')
//   - 'department' (targetId = Department.id)
//   - 'role'       (targetId = UserRole enum value, e.g. 'student')
//   - 'program'    (targetId = Department.code for the FCDS programs)
//
// `isTimeWindow=true`  => lock is ACTIVE outside [openFrom, openTo].
// `isTimeWindow=false` => lock active until `expiresAt` (NULL = forever).
model LoginLock {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  targetKind   String    @map("target_kind")
  targetId     String    @map("target_id")
  reason       String
  isTimeWindow Boolean   @default(false) @map("is_time_window")
  openFrom     DateTime? @map("open_from")
  openTo       DateTime? @map("open_to")
  expiresAt    DateTime? @map("expires_at")
  createdBy    String?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  releasedAt   DateTime? @map("released_at")
  releasedBy   String?   @map("released_by")

  creator  User? @relation("LoginLockCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  releaser User? @relation("LoginLockReleaser", fields: [releasedBy], references: [id], onDelete: SetNull)

  @@index([targetKind, targetId])
  @@index([releasedAt])
  @@index([tenantId])
  @@map("login_locks")
