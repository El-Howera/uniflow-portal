{
  "name": "uniflow-portal",
  "version": "0.1.0",
  "private": true,
  "description": "UniFlow Portal — multi-role college portal (React 19 + Express + Prisma + Mistral RAG). MVP — Student & Professor run on the full backend; other dashboards are front-end UI previews.",
  "author": "Elfares Howera <elhowera@gmail.com>",
  "scripts": {
    "start": "npm --prefix frontend start",
    "build": "npm --prefix frontend run build",
    "test": "npm --prefix frontend test -- --watchAll=false --passWithNoTests",
    "lint": "npm --prefix frontend run lint",
    "typecheck": "npx tsc --noEmit -p frontend/tsconfig.json",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "seed": "node backend/scripts/seed.js",
    "seed:minimal": "node backend/scripts/seed-minimal.js",
    "seed:roles": "node backend/scripts/seed-roles.js",
    "ws-server": "node backend/servers/websocket/index.js",
    "reg-server": "node backend/servers/registration/index.js",
    "att-server": "node backend/servers/attendance/index.js",
    "pay-server": "node backend/servers/payments/index.js",
    "content-server": "node backend/servers/course-content/index.js",
    "affairs-server": "node backend/servers/student-affairs/index.js",
    "profile-server": "node backend/servers/user-profile/index.js",
    "notification-server": "node backend/servers/notification/index.js",
    "chat-server": "node backend/servers/chat/index.js",
    "chatbot": "node backend/servers/chatbot/index.js",
    "servers": "concurrently -n WS,REG,ATT,PAY,CON,SA,PROF,CHATBOT,NOTIF,CHAT \"npm:ws-server\" \"npm:reg-server\" \"npm:att-server\" \"npm:pay-server\" \"npm:content-server\" \"npm:affairs-server\" \"npm:profile-server\" \"npm:chatbot\" \"npm:notification-server\" \"npm:chat-server\"",
    "dev": "concurrently -n WEB,SERVERS \"npm:start\" \"npm:servers\""
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma",
    "seed": "node backend/scripts/seed.js"
  },
  "dependencies": {
    "@mistralai/mistralai": "^1.5.0",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.15.1",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "firebase-admin": "^12.7.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.18.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.8.3",
    "stripe": "^22.1.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prisma": "^5.22.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "rimraf": "^5.0.10",
    "glob": "^10.4.5"
  }
}
